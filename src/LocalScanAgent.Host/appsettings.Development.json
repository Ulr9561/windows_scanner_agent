{
  "Agent": {
    "BindAddress": "127.0.0.1",
    "Port": 18765,
    "AllowOnlyOneScanAtATime": true,
    "PreferredDriverOrder": [ "twain", "wia" ],
    "TempRoot": "temp",
    "Mode": "Fake"
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Logging": {
    "Path": "logs/agent-.log",
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

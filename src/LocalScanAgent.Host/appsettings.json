{
  "Agent": {
    "BindAddress": "127.0.0.1",
    "Port": 18765,
    "AllowOnlyOneScanAtATime": true,
    "PreferredDriverOrder": [ "twain", "wia" ],
    "TempRoot": "temp",
    "Mode": "Real",
    "Quality": {
      "AutoDeskew": true,
      "MaxQuality": true,
      "BrightnessContrastAfterScan": true,
      "Brightness": 0,
      "Contrast": 100,
      "ExcludeBlankPages": false,
      "BlankPageWhiteThreshold": 99,
      "BlankPageCoverageThreshold": 2,
      "CropToPageSize": false,
      "PageSize": "A4",
      "JpegQuality": 90
    }
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Logging": {
    "Path": "logs/agent-.log",
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
